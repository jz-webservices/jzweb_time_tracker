<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action: My Entries (filtered to current user) -->
    <record id="action_time_entry_my" model="ir.actions.act_window">
        <field name="name">My Time Entries</field>
        <field name="res_model">time.entry</field>
        <field name="view_mode">list,form,calendar,pivot,graph</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'default_user_id': uid}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No time entries yet.
            </p>
            <p>
                Create a new entry, select a project and task, then click
                <b>Start</b> to begin tracking your time.
            </p>
        </field>
    </record>

    <!-- Action: All Entries (Manager) -->
    <record id="action_time_entry_all" model="ir.actions.act_window">
        <field name="name">All Time Entries</field>
        <field name="res_model">time.entry</field>
        <field name="view_mode">list,form,calendar,pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No time entries found.
            </p>
        </field>
    </record>

    <!-- Action: Calendar -->
    <record id="action_time_entry_calendar" model="ir.actions.act_window">
        <field name="name">Time Calendar</field>
        <field name="res_model">time.entry</field>
        <field name="view_mode">calendar,list,form</field>
    </record>

    <!-- Action: Report / Auswertung (pivot default) -->
    <record id="action_time_entry_report" model="ir.actions.act_window">
        <field name="name">Time Report</field>
        <field name="res_model">time.entry</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{
            'search_default_group_task': 1
        }</field>
    </record>

    <!-- Top-Level Menu -->
    <menuitem
        id="menu_jzweb_time_tracker_root"
        name="Time Tracker"
        sequence="90"
        web_icon="jzweb_time_tracker,static/description/icon.svg"
    />

    <!-- Sub-Menus -->
    <menuitem
        id="menu_time_entry_my"
        name="My Entries"
        parent="menu_jzweb_time_tracker_root"
        action="action_time_entry_my"
        sequence="10"
        groups="jzweb_time_tracker.group_user,jzweb_time_tracker.group_manager"
    />
    <menuitem
        id="menu_time_entry_all"
        name="All Entries"
        parent="menu_jzweb_time_tracker_root"
        action="action_time_entry_all"
        sequence="20"
        groups="jzweb_time_tracker.group_manager"
    />
    <menuitem
        id="menu_time_entry_calendar"
        name="Calendar"
        parent="menu_jzweb_time_tracker_root"
        action="action_time_entry_calendar"
        sequence="30"
        groups="jzweb_time_tracker.group_user,jzweb_time_tracker.group_manager"
    />
    <menuitem
        id="menu_time_entry_report"
        name="Auswertung"
        parent="menu_jzweb_time_tracker_root"
        action="action_time_entry_report"
        sequence="40"
        groups="jzweb_time_tracker.group_user,jzweb_time_tracker.group_manager"
    />
</odoo>
