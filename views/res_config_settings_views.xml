<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.time.tracker</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Time Tracker" name="jzweb_time_tracker">
                    <block title="Zeiterfassung">
                        <setting string="Stoppzeit aufrunden"
                                 help="Rundet die Stoppzeit auf das nächste Intervall auf (z.B. 08:13 → 08:15 bei 15-Minuten-Rundung).">
                            <field name="time_tracker_rounding"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
