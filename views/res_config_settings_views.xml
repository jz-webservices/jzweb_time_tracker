<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="time_tracker_config_form_view" model="ir.ui.view">
        <field name="name">time.tracker.config.form</field>
        <field name="model">time.tracker.config</field>
        <field name="arch" type="xml">
            <form string="Time Tracker Einstellungen">
                <sheet>
                    <group string="Zeitrundung">
                        <field name="rounding_minutes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_time_tracker_config" model="ir.actions.act_window">
        <field name="name">Einstellungen</field>
        <field name="res_model">time.tracker.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
