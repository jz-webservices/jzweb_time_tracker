<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Category -->
    <record id="module_jzweb_time_tracker_category" model="ir.module.category">
        <field name="name">Time Tracker</field>
        <field name="sequence">20</field>
    </record>

    <!-- Groups -->
    <record id="group_user" model="res.groups">
        <field name="name">User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">
            Can create and manage their own time entries.
        </field>
    </record>

    <record id="group_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="implied_ids" eval="[(4, ref('jzweb_time_tracker.group_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        <field name="comment">
            Can view and manage all users' time entries.
        </field>
    </record>

    <!-- Record Rules -->

    <!-- Users: read/write/create/delete only own records -->
    <record id="rule_time_entry_user_own" model="ir.rule">
        <field name="name">Time Entry: Users see own entries</field>
        <field name="model_id" ref="model_time_entry"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('jzweb_time_tracker.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Managers: see all records (no domain restriction) -->
    <record id="rule_time_entry_manager_all" model="ir.rule">
        <field name="name">Time Entry: Managers see all entries</field>
        <field name="model_id" ref="model_time_entry"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('jzweb_time_tracker.group_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
